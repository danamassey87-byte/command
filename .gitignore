# Build artifacts
frontend/dist/
frontend/node_modules/

# OS / editor junk
.DS_Store
*.swp
.idea/
.vscode/

# Downloaded / archive artifacts that should never be checked in
*.zip

# Local environment secrets (keep .env.example committed; never .env or .env.local)
.env
.env.local
.env.*.local

# Supabase ephemeral state
supabase/.branches/

# Local Claude config — contains OAuth tokens, must never be tracked
.claude/settings.local.json
.claude/.credentials.json

# Supabase CLI cache
supabase/.temp/
